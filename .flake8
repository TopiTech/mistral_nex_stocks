[flake8]
max-line-length = 100
# E203 whitespace before ':' (not PEP8 compliant but used by black/ruff)
# E402 module level import not at top of file (intentional in some places)
# W503 line break before binary operator (not PEP8 compliant, W504 is preferred)
# E501 line too long
# E302 expected 2 blank lines
# E303 too many blank lines
# E305 expected 2 blank lines after class or function definition
# W293 blank line contains whitespace
# E131 continuation line unaligned for hanging indent
# E261 at least two spaces before inline comment
extend-ignore = E203, E402, W503, E501, E302, E303, E305, W293, E131, E261
exclude =
    .git,
    __pycache__,
    .mimocode,
    .venv,
    .tox,
    .mypy_cache,
    .pytest_cache,
    .ruff_cache,
    node_modules,
    tests
per-file-ignores =
    services/search_service.py: F401
