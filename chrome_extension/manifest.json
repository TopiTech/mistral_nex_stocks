{
  "manifest_version": 3,
  "name": "Mistral NeX Stocks Launcher",
  "version": "1.2.2",
  "description": "ローカル Flask バックエンドを起動し、Mistral NeX Stocks を開く個人用ランチャー。",
  "permissions": [
    "nativeMessaging",
    "storage",
    "tabs",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Mistral NeX Stocks",
    "default_popup": "popup.html"
  }
}
